```gitignore
# Dependencies
node_modules/

# Build artifacts
dist/
build/
*.min.js
*.min.css
*.bundle.js

# Environment variables
.env
.env.local
*.env.*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.Python
*.egg-info/
.eggs/

# OS generated files
.DS_Store
Thumbs.db

# Testing
.nyc_output/
coverage/
*.lcov
```