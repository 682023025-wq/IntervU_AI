```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.min.js
*.min.css
*.bundle.js

# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Coverage reports
coverage/
htmlcov/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS generated files
.DS_Store
Thumbs.db

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Compiled files
*.exe
*.dll
*.so
*.a
*.o
*.obj
*.out

# Cache directories
.cache/
.mypy_cache/
.pytest_cache/
.nyc_output/
coverage/

# Distribution / packaging
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
```