```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.min.js
*.min.css
bundle.js

# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Coverage reports
coverage/
htmlcov/
*.coverage

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.venv/
venv/
.env
pip-log.txt
pip-delete-this-directory.txt

# Compressed files
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.rar
*.7z
```